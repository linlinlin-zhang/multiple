# ORYZAE Image Board Environment Variables
# Copy this file to .env and fill in your actual values.

# Server
PORT=3000

# Database (PostgreSQL)
# Adjust user, password, host, port, and database name as needed.
DATABASE_URL="postgresql://user:password@localhost:5432/oryzae?schema=public"

# File Storage
STORAGE_PATH="./storage"

# Chat: Kimi K2.6 no thinking
KIMI_API_KEY=
CHAT_PROVIDER=kimi
CHAT_API_BASE_URL=https://api.moonshot.cn/v1
CHAT_MODEL=kimi-k2.6

# Vision analysis: Kimi K2.6 no thinking
ANALYSIS_PROVIDER=kimi
ANALYSIS_API_BASE_URL=https://api.moonshot.cn/v1
ANALYSIS_MODEL=kimi-k2.6

# Image generation: Tencent Cloud TokenHub HY-Image-V3.0
TENCENT_TOKENHUB_API_KEY=
IMAGE_PROVIDER=tencent-tokenhub-image
IMAGE_API_BASE_URL=https://tokenhub.tencentmaas.com/v1/api/image
IMAGE_MODEL=hy-image-v3.0

# Speech to text: separate ASR API/model
ASR_API_KEY=
ASR_PROVIDER=openai-audio-transcriptions
ASR_API_BASE_URL=https://api.openai.com/v1
ASR_MODEL=whisper-1

# Realtime voice control: separate audio-capable API/model
REALTIME_API_KEY=
REALTIME_PROVIDER=openai-audio-chat
REALTIME_API_BASE_URL=https://api.openai.com/v1
REALTIME_MODEL=gpt-4o-audio-preview

# Image polling settings
IMAGE_POLL_INTERVAL_MS=2000
IMAGE_POLL_ATTEMPTS=30

# TokenHub docs require reference images to be accessible URLs.
# Keep false unless you confirm your gateway accepts data:image URLs.
IMAGE_INCLUDE_DATA_URL=false
