# ThoughtGrid Environment Variables
# Copy this file to .env and fill in your actual values.

# Server
PORT=3000

# Database (PostgreSQL)
# Adjust user, password, host, port, and database name as needed.
DATABASE_URL="postgresql://user:password@localhost:5432/oryzae?schema=public"

# File Storage
STORAGE_PATH="./storage"

# MiMo main controller
# Used by the default chat/canvas controller and vision/file analysis roles.
MIMO_API_KEY=

# DashScope / Alibaba Cloud Model Studio
# Used by image/video generation, speech/realtime, embeddings, image search,
# and deep research unless those roles are configured with their own keys.
DASHSCOPE_API_KEY=

# Chat and canvas controller: MiMo V2.5 Pro
CHAT_PROVIDER=openai-compatible
CHAT_API_BASE_URL=https://api.xiaomimimo.com/v1
CHAT_MODEL=mimo-v2.5-pro
CHAT_OPTIONS={"max_tokens":65536,"enableCanvasTools":true,"enableWebSearch":false,"enableWebExtractor":false,"enableCodeInterpreter":false,"enablePreviousResponse":false,"enableThinkingParam":true}

# Vision, file understanding, and lightweight analysis: MiMo V2.5 Pro
ANALYSIS_PROVIDER=openai-compatible
ANALYSIS_API_BASE_URL=https://api.xiaomimimo.com/v1
ANALYSIS_MODEL=mimo-v2.5-pro
ANALYSIS_OPTIONS={"max_tokens":65536,"enableWebSearch":false,"jsonObjectResponse":true,"enableThinkingParam":true}

# Image search remains an independent DashScope Responses capability.
IMAGE_SEARCH_API_KEY=
IMAGE_SEARCH_PROVIDER=dashscope-qwen
IMAGE_SEARCH_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IMAGE_SEARCH_MODEL=qwen3.5-plus

# Image generation: Alibaba Cloud Model Studio Qwen Image 2.0 Pro
# Uses DASHSCOPE_API_KEY by default; IMAGE_API_KEY can override it.
IMAGE_API_KEY=
IMAGE_PROVIDER=dashscope-qwen-image
IMAGE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
IMAGE_MODEL=qwen-image-2.0-pro
IMAGE_OPTIONS={"size":"2048*2048","n":1,"prompt_extend":true,"watermark":false,"useReferenceImage":true}

# Speech to text: Qwen3 LiveTranslate Flash via DashScope compatible-mode streaming API.
ASR_API_KEY=
ASR_PROVIDER=dashscope-livetranslate
ASR_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ASR_MODEL=qwen3-livetranslate-flash-2025-12-01

# Realtime voice control: Qwen3.5 Omni Realtime via DashScope WebSocket.
REALTIME_API_KEY=
REALTIME_PROVIDER=dashscope-realtime
REALTIME_API_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
REALTIME_MODEL=qwen3.5-omni-plus-realtime

# Deep research workflow: Qwen Deep Research.
DEEPTHINK_API_KEY=
DEEPTHINK_PROVIDER=dashscope-deep-research
DEEPTHINK_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
DEEPTHINK_MODEL=qwen-deep-research

# Image generation polling settings
IMAGE_POLL_INTERVAL_MS=2000
IMAGE_POLL_ATTEMPTS=30

# Keep false unless your image gateway explicitly accepts data:image URLs.
IMAGE_INCLUDE_DATA_URL=false

# Session-level RAG embeddings: DashScope text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024


# Video generation: Alibaba Cloud Model Studio HappyHorse
# Uses DASHSCOPE_API_KEY by default; VIDEO_API_KEY can override it.
VIDEO_API_KEY=
VIDEO_PROVIDER=dashscope-happyhorse-video
VIDEO_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/video-generation/video-synthesis
VIDEO_MODEL=happyhorse-1.0-i2v
VIDEO_OPTIONS={"resolution":"720P","ratio":"16:9","duration":5,"watermark":false,"useReferenceImage":true,"imageModel":"happyhorse-1.0-i2v","textModel":"happyhorse-1.0-t2v","pollIntervalMs":15000,"pollAttempts":30}

# Video generation polling and timeout settings
VIDEO_POLL_INTERVAL_MS=15000
VIDEO_POLL_ATTEMPTS=30
VIDEO_SUBMIT_TIMEOUT_MS=60000
VIDEO_DOWNLOAD_TIMEOUT_MS=180000
# Main-controller model candidates for tool-use comparison
# Keep CHAT_* on the active baseline; copy one candidate into CHAT_* to test it as the controller.
CONTROLLER_MODEL_CANDIDATE_BASELINE_PROVIDER=openai-compatible
CONTROLLER_MODEL_CANDIDATE_BASELINE_API_BASE_URL=https://api.xiaomimimo.com/v1
CONTROLLER_MODEL_CANDIDATE_BASELINE_MODEL=mimo-v2.5-pro
CONTROLLER_MODEL_CANDIDATE_BASELINE_API_KEY=
CONTROLLER_MODEL_CANDIDATE_BASELINE_OPTIONS={"max_tokens":65536,"enableCanvasTools":true,"enableWebSearch":false,"enablePreviousResponse":false,"enableThinkingParam":true}

# MiMo V2.5 Pro candidate — fill the OpenAI-compatible endpoint and key for your provider.
CONTROLLER_MODEL_CANDIDATE_MIMO_PROVIDER=openai-compatible
CONTROLLER_MODEL_CANDIDATE_MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
CONTROLLER_MODEL_CANDIDATE_MIMO_MODEL=mimo-v2.5-pro
CONTROLLER_MODEL_CANDIDATE_MIMO_API_KEY=
CONTROLLER_MODEL_CANDIDATE_MIMO_OPTIONS={"max_tokens":65536,"enableCanvasTools":true,"enableWebSearch":false,"enablePreviousResponse":false,"enableThinkingParam":true}

# Kimi K2.6 candidate — Moonshot OpenAI-compatible API.
CONTROLLER_MODEL_CANDIDATE_KIMI_PROVIDER=kimi
CONTROLLER_MODEL_CANDIDATE_KIMI_API_BASE_URL=https://api.moonshot.cn/v1
CONTROLLER_MODEL_CANDIDATE_KIMI_MODEL=kimi-k2.6
CONTROLLER_MODEL_CANDIDATE_KIMI_API_KEY=
CONTROLLER_MODEL_CANDIDATE_KIMI_OPTIONS={"max_tokens":65536,"enableCanvasTools":true,"enableWebSearch":false,"enablePreviousResponse":false}
# DeepSeek V4 Pro candidate — OpenAI-compatible API.
CONTROLLER_MODEL_CANDIDATE_DEEPSEEK_PROVIDER=deepseek
CONTROLLER_MODEL_CANDIDATE_DEEPSEEK_API_BASE_URL=https://api.deepseek.com
CONTROLLER_MODEL_CANDIDATE_DEEPSEEK_MODEL=deepseek-v4-pro
CONTROLLER_MODEL_CANDIDATE_DEEPSEEK_API_KEY=
CONTROLLER_MODEL_CANDIDATE_DEEPSEEK_OPTIONS={"max_tokens":65536,"enableCanvasTools":true,"enableWebSearch":false,"enablePreviousResponse":false}
