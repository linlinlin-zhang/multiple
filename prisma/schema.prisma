generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector(version: "0.8.1.2")]
}

model Session {
  id        String   @id @default(uuid())
  title     String   @default("未命名会话")
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nodes     Node[]
  links     Link[]
  assets    Asset[]
  chatMessages ChatMessage[]
  shareTokens ShareToken[]
  viewState Json?    // { x, y, scale }
}

model Node {
  id        String  @id @default(uuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nodeId    String  // client-side node id: "source", "analysis", "option-evidence-board", etc.
  type      String  // "source" | "analysis" | "option" | "generated"
  x         Float
  y         Float
  width     Float
  height    Float
  data      Json?   // flexible per-node payload: option object, generated image hash, etc.
  collapsed Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Link {
  id        String  @id @default(uuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  fromNodeId String // client-side node id
  toNodeId   String // client-side node id
  kind       String // "analysis" | "option" | "generated"
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Asset {
  id        String  @id @default(uuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  hash      String  // SHA-256 content hash
  kind      String  // "upload" | "generated"
  mimeType  String
  fileSize  Int
  fileName  String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([hash])
}

model ChatMessage {
  id        String  @id @default(uuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String  // "user" | "assistant"
  content   String
  thinkingContent String? // assistant chain-of-thought trace
  references Json?  // [{ title, url, description, type }]
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model ShareToken {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  token        String   @unique @default(uuid())
  createdAt    DateTime @default(now())
  expiresAt    DateTime?
  snapshotData Json?    // immutable frozen session state

  @@index([token])
  @@index([sessionId])
}

model Settings {
  id          String   @id @default(uuid())
  role        String   @unique // "analysis" | "chat" | "image" | "global"
  endpoint    String   @default("")
  model       String   @default("")
  apiKey      String   @default("")
  temperature Float    @default(0.7)
  options     Json     @default("{}")
  theme       String   @default("light")
  language    String   @default("zh")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MaterialItem {
  id        String   @id @default(uuid())
  fileName  String
  mimeType  String
  fileSize  Int
  hash      String   // SHA-256 content hash
  filePath  String   // relative path in storage/material/
  favorited Boolean  @default(false)
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hash])
  @@index([fileName])
  @@index([addedAt])
  @@index([favorited])
}

model FileUnderstanding {
  id                   String   @id @default(uuid())
  hash                 String   @unique // SHA-256 content hash
  fileName             String
  mimeType             String
  summary              String   @default("")
  abstract             String   @default("")
  structure            Json?    // { totalPages, outline, sections }
  keyMaterials         Json?    // { images, tables, charts }
  actionableDirections Json?    // [{ type, title, description, rationale }]
  isScanned            Boolean  @default(false)
  metadata             Json?    // { title, author }
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([hash])
}

/// Session-scoped retrieval chunks (RAG).
/// embedding column is `vector(1024)` managed via raw SQL — Prisma marks it Unsupported.
/// Source kinds: "file" | "web" | "card" | "chat" | "generated" | "analysis" | "note"
model ContextChunk {
  id          String   @id @default(uuid())
  sessionId   String
  kind        String
  sourceId    String?  // FK-like reference to Node/Asset/ChatMessage etc., free-form
  sourceMeta  Json?    // { fileName, page, url, nodeId, hash, role, ... }
  chunkIndex  Int      @default(0)
  content     String
  tokens      Int      @default(0)
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([sessionId, kind])
  @@index([sourceId])
}
