generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector(version: "0.8.1.2")]
}

model Session {
  id           String        @id @default(uuid())
  title        String        @default("未命名会话")
  isDemo       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  viewState    Json?
  visitorId    String        @default("legacy")
  assets       Asset[]
  chatMessages ChatMessage[]
  links        Link[]
  nodes        Node[]
  shareTokens  ShareToken[]

  @@index([visitorId, updatedAt])
}

model Node {
  id        String   @id @default(uuid())
  sessionId String
  nodeId    String
  type      String
  x         Float
  y         Float
  width     Float
  height    Float
  data      Json?
  collapsed Boolean  @default(false)
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Link {
  id         String   @id @default(uuid())
  sessionId  String
  fromNodeId String
  toNodeId   String
  kind       String
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Asset {
  id        String   @id @default(uuid())
  sessionId String
  hash      String
  kind      String
  mimeType  String
  fileSize  Int
  fileName  String?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([hash])
}

model ChatMessage {
  id              String   @id @default(uuid())
  sessionId       String
  role            String
  content         String
  createdAt       DateTime @default(now())
  thinkingContent String?
  references      Json?
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model ShareToken {
  id           String    @id @default(uuid())
  sessionId    String
  token        String    @unique @default(uuid())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  snapshotData Json?
  session      Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([sessionId])
}

model Settings {
  id          String   @id @default(uuid())
  role        String   @unique
  endpoint    String   @default("")
  model       String   @default("")
  apiKey      String   @default("")
  temperature Float    @default(0.7)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  theme       String   @default("light")
  language    String   @default("zh")
  options     Json     @default("{}")
}

model MaterialItem {
  id             String           @id @default(uuid())
  fileName       String
  mimeType       String
  fileSize       Int
  hash           String
  filePath       String
  addedAt        DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  favorited      Boolean          @default(false)
  visitorId      String           @default("legacy")
  source         String           @default("user")
  MaterialHidden MaterialHidden[]

  @@index([hash])
  @@index([fileName])
  @@index([addedAt])
  @@index([favorited])
  @@index([visitorId, addedAt])
  @@index([visitorId, hash])
  @@index([source])
}

model FileUnderstanding {
  id                   String   @id @default(uuid())
  hash                 String   @unique
  fileName             String
  mimeType             String
  summary              String   @default("")
  abstract             String   @default("")
  structure            Json?
  keyMaterials         Json?
  actionableDirections Json?
  isScanned            Boolean  @default(false)
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([hash])
}

/// Session-scoped retrieval chunks (RAG).
/// embedding column is `vector(1024)` managed via raw SQL — Prisma marks it Unsupported.
/// Source kinds: "file" | "web" | "card" | "chat" | "generated" | "analysis" | "note"
model ContextChunk {
  id         String                 @id @default(uuid())
  sessionId  String
  kind       String
  sourceId   String?
  sourceMeta Json?
  chunkIndex Int                    @default(0)
  content    String
  tokens     Int                    @default(0)
  embedding  Unsupported("vector")?
  createdAt  DateTime               @default(now())

  @@index([sessionId])
  @@index([sessionId, kind])
  @@index([sourceId])
}

model MaterialHidden {
  id           String       @id
  visitorId    String
  materialId   String
  hiddenAt     DateTime     @default(now())
  MaterialItem MaterialItem @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([visitorId, materialId])
  @@index([visitorId])
}
